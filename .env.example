# Copy to .env locally. On Vercel, add the same keys in Project Settings -> Environment Variables.

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Auth — use long random strings in production
JWT_SECRET="change-me"
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="https://your-app.vercel.app"

# Expert mode (OpenRouter)
OPENROUTER_API_KEY="sk-or-v1-..."

# Fast mode (Ollama on your PC, exposed via tunnel — NOT localhost on Vercel)
# Local dev:
# OLLAMA_URL="http://localhost:11434"
# Production on Vercel (after running scripts/start-ollama-tunnel.ps1 + ngrok):
# OLLAMA_URL="https://your-subdomain.ngrok-free.app"
OLLAMA_URL="http://localhost:11434"
OLLAMA_API_KEY=""

# Model tuning
FAST_MODEL_TEMPERATURE=0.7
EXPERT_MODEL_TEMPERATURE=0.7
FAST_MAX_OUTPUT_TOKENS=512
EXPERT_ERROR_THRESHOLD=3
FAST_MODEL_NAME="hf.co/bartowski/Llama-3.1-8B-Lexi-Uncensored-V2-GGUF:Q4_K_M"
EXPERT_MODEL_NAME="nvidia/nemotron-3-ultra-550b-a55b:free"
